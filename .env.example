# ============================================
# ELI LILLY AGENTIC AI - ENVIRONMENT VARIABLES
# ============================================

# Copy this file to .env and update values

# ============================================
# LLM CONFIGURATION
# ============================================
# Options: ollama (free local) or openai (paid)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# OBSERVABILITY (Optional)
# ============================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=eli-lilly-pharmacy-ai

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# APPLICATION SETTINGS
# ============================================
LOG_LEVEL=INFO
TOP_K_RETRIEVAL=5
HIGH_RISK_THRESHOLD=0.6
HITL_THRESHOLD=0.5